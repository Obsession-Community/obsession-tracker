# Obsession Tracker Environment Configuration
# Copy this file to .env and configure your settings

# ============================================================
# REQUIRED: API Keys for Build
# These are passed to Flutter via --dart-define flags
# ============================================================

# Mapbox access token (required for map rendering)
# Sign up at: https://account.mapbox.com/
# Create a public token (pk.*) with default scopes
MAPBOX_ACCESS_TOKEN=

# National Park Service API key (required for NPS park data)
# Sign up at: https://developer.nps.gov/signup/
NPS_API_KEY=

# ============================================================
# App Configuration
# ============================================================
APP_NAME=Obsession Tracker
APP_VERSION=0.1.0
APP_ENV=development

# Database Configuration
DB_NAME=obsession_tracker.db
DB_VERSION=1

# Map Configuration
# OpenStreetMap tile server (default uses public OSM)
MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
MAP_ATTRIBUTION=© OpenStreetMap contributors

# Optional: Custom tile server configuration
# MAP_TILE_URL=https://your-custom-tile-server.com/{z}/{x}/{y}.png
# MAP_API_KEY=your_api_key_here

# GPS and Location Settings
GPS_UPDATE_INTERVAL=5000  # milliseconds
GPS_ACCURACY_THRESHOLD=10 # meters
GPS_DISTANCE_FILTER=5     # meters

# Privacy Settings
ENABLE_CRASH_REPORTING=false
ENABLE_ANALYTICS=false
ENABLE_TELEMETRY=false

# Security Settings
ENABLE_BIOMETRIC_AUTH=true
SESSION_TIMEOUT=900000 # 15 minutes in milliseconds
AUTO_LOCK_ENABLED=true

# Export Settings
DEFAULT_EXPORT_FORMAT=gpx
EXPORT_COMPRESSION=true
MAX_EXPORT_SIZE=10485760 # 10MB in bytes

# Development Settings (only used in development)
DEBUG_MODE=true
ENABLE_FLUTTER_INSPECTOR=true
LOG_LEVEL=debug

# Feature Flags
ENABLE_VOICE_NOTES=true
ENABLE_PHOTO_CAPTURE=true
ENABLE_OFFLINE_MAPS=true
ENABLE_ROUTE_PLANNING=false # Future feature

# Performance Settings
MAP_CACHE_SIZE=104857600      # 100MB in bytes
IMAGE_CACHE_SIZE=52428800     # 50MB in bytes
TILE_CACHE_DURATION=604800000 # 1 week in milliseconds

# Backup Settings
AUTO_BACKUP_ENABLED=false # Local backups only
BACKUP_FREQUENCY=daily
MAX_BACKUP_FILES=7

# Experimental Features (use with caution)
ENABLE_EXPERIMENTAL_UI=false
ENABLE_BETA_FEATURES=false

# Platform-specific Settings
# Android
ANDROID_MIN_SDK=21
ANDROID_TARGET_SDK=34

# iOS
IOS_MIN_VERSION=12.0
IOS_TARGET_VERSION=17.0

# Notes:
# - All privacy settings default to privacy-first values
# - No cloud services are enabled by default
# - All data remains local unless explicitly configured otherwise
# - Map tiles are cached locally for offline use
# - Biometric authentication is recommended for sensitive data
