<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Configuration for Obsession Tracker

    Security features:
    - Enforces HTTPS for all production traffic
    - Allows localhost for development/debugging
    - Certificate pinning for API endpoints (optional, see comments)
    - Disables cleartext traffic in release builds
-->
<network-security-config>
    <!-- Base configuration for all domains -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust system CAs only -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Production API endpoint (Droplet - tracker-api) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">obsessiontracker.com</domain>
        <domain includeSubdomains="true">obsession.community</domain>
        <domain includeSubdomains="true">tracker-api.obsession.community</domain>

        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>

        <!--
            Certificate Pinning (Optional - uncomment when ready)

            To enable certificate pinning:
            1. Get the SHA-256 hash of your certificate's public key
            2. Run: openssl s_client -connect tracker-api.obsession.community:443 | openssl x509 -pubkey -noout | openssl pkey -pubin -outform der | openssl dgst -sha256 -binary | openssl enc -base64
            3. Replace the placeholder below with your actual pin
            4. Include a backup pin (your CA's intermediate certificate)

            WARNING: Incorrect pinning can lock users out of your app!
            Always include backup pins and have a pin rotation strategy.

        <pin-set expiration="2026-12-31">
            <pin digest="SHA-256">YOUR_PRIMARY_PIN_HERE=</pin>
            <pin digest="SHA-256">YOUR_BACKUP_PIN_HERE=</pin>
        </pin-set>
        -->
    </domain-config>

    <!-- Mapbox tiles (required for maps) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">mapbox.com</domain>
        <domain includeSubdomains="true">tiles.mapbox.com</domain>
        <domain includeSubdomains="true">api.mapbox.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!--
        Local tile server for MBTiles historical maps
        Allows cleartext HTTP to localhost addresses for serving tiles locally.
        - 127.0.0.1: Device's localhost (iOS/physical devices)
        - 10.0.2.2: Android emulator's host machine localhost
        - localhost: Alias for 127.0.0.1
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>

    <!--
        Debug configuration - allows localhost for development
        This only applies to debug builds due to the debugOverrides flag
    -->
    <debug-overrides>
        <trust-anchors>
            <!-- Trust user-installed CAs for debugging (e.g., Charles Proxy) -->
            <certificates src="user" />
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
