      key_path = ENV["APP_STORE_CONNECT_API_KEY_PATH"] ||
                 "fastlane/AuthKey_#{ENV['APP_STORE_CONNECT_API_KEY_ID']}.p8"
      app_store_connect_api_key(
        key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
        issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
        key_filepath: key_path,
        duration: 1200,
        in_house: false
      )
    end

    # List macOS screenshots being uploaded
    # macOS uses separate screenshots folder to avoid conflicts with iOS screenshots
    screenshot_dir = "screenshots_mac/en-US"
    mac_screenshots = Dir.glob("#{screenshot_dir}/*APP_DESKTOP*.png")
    UI.message("Found #{mac_screenshots.count} macOS screenshots to upload:")
    mac_screenshots.sort.each { |f| UI.message("  📷 #{File.basename(f)}") }

    deliver(
      app_identifier: ENV["APP_IDENTIFIER"] || "com.obsessioncommunity.tracker",
