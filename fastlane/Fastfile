  end

  desc "Generate AND upload macOS screenshots to App Store Connect"
  lane :screenshots_full do
    screenshots_generate
    screenshots_upload
  end

  desc "Submit existing TestFlight build to Mac App Store for review (no rebuild)"
  lane :submit_for_review do |options|
    # This lane submits an EXISTING TestFlight build to the Mac App Store for review.
    # Use this when you already have a build in TestFlight that you want to release.
    #
    # Usage:
    #   fastlane mac submit_for_review                    # Uses latest build
    #   fastlane mac submit_for_review build_number:123   # Uses specific build
    #   fastlane mac submit_for_review version:1.0.0      # For specific version

    if ENV["APP_STORE_CONNECT_API_KEY_ID"]
      key_path = ENV["APP_STORE_CONNECT_API_KEY_PATH"] ||
                 "fastlane/AuthKey_#{ENV['APP_STORE_CONNECT_API_KEY_ID']}.p8"
      app_store_connect_api_key(
        key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
        issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
        key_filepath: key_path,
        duration: 1200,
        in_house: false
      )
    end

    deliver_options = {
      app_identifier: ENV["APP_IDENTIFIER"] || "com.obsessioncommunity.tracker",
      platform: "osx",
      submit_for_review: true,
      automatic_release: options[:automatic_release] != false,
      force: true,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      precheck_include_in_app_purchases: false,
      team_id: "128579436",
      dev_portal_team_id: "686BSNR73Z",
      submission_information: {
        add_id_info_serves_ads: false,
        add_id_info_tracks_action: false,
        add_id_info_tracks_install: false,
        add_id_info_uses_idfa: false,
        content_rights_has_rights: true,
        content_rights_contains_third_party_content: true,
        export_compliance_uses_encryption: true,
        export_compliance_is_exempt: true,
        export_compliance_contains_proprietary_cryptography: false,
        export_compliance_contains_third_party_cryptography: false
      }
    }

    if options[:build_number]
      deliver_options[:build_number] = options[:build_number].to_s
      UI.message("Submitting macOS build #{options[:build_number]} for review...")
    else
      UI.message("Submitting latest macOS TestFlight build for review...")
    end

    if options[:version]
      deliver_options[:app_version] = options[:version]
    end

    deliver(deliver_options)

    UI.success("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    UI.success("✅ macOS app submitted for review!")
    UI.success("")
    UI.success("Next steps:")
    UI.success("  1. Check App Store Connect for review status")
    UI.success("  2. Respond to any reviewer questions")
    UI.success("  3. Once approved, your app will be released automatically")
    UI.success("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
  end

  # Error handling
  error do |lane, exception|
    UI.error("Error in lane #{lane}: #{exception.message}")
  end
end

platform :android do
  desc "Push a new beta build to Google Play internal testing"
  lane :beta do |options|
    # Build number MUST be provided to keep iOS/Android in sync
    build_number = options[:build_number]
    UI.user_error!("build_number is required. Use: fastlane android beta build_number:XX") unless build_number

    # Build with Flutter (ensures consistent build across platforms)
    sh("flutter", "pub", "get")
    sh("flutter", "clean") unless ENV["SKIP_FLUTTER_CLEAN"]
    sh("flutter", "build", "appbundle",
       "--release",
       "--build-number=#{build_number}")

    # Upload to Google Play internal track
    upload_to_play_store(
      track: "internal",
      aab: "build/app/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true,
      json_key: ENV["SUPPLY_JSON_KEY"] || "fastlane/google-play-key.json"
    )
  end

  desc "Upload metadata (text only) to Google Play - NO images or screenshots"
  lane :metadata do
    begin
      upload_to_play_store(
        skip_upload_apk: true,
        skip_upload_aab: true,
        skip_upload_images: true,        # Use screenshots_upload lane for images
        skip_upload_screenshots: true,   # Use screenshots_upload lane for screenshots
        skip_upload_changelogs: true,    # Changelogs require version_code (uploaded with builds)
        json_key: ENV["SUPPLY_JSON_KEY"] || "fastlane/google-play-key.json"
      )
    rescue => ex
      if ex.message.include?("No data") || ex.message.include?("size") || ex.message.include?("nil:NilClass")
        UI.error("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
        UI.error("No app found in Google Play Console")
        UI.error("")
        UI.error("This means you need to create the app listing first:")
        UI.error("  1. Go to https://play.google.com/console")
        UI.error("  2. Create your app (Obsession Tracker)")
        UI.error("  3. Create at least one release (internal/alpha/beta)")
        UI.error("  4. Then run: bundle exec fastlane android metadata")
        UI.error("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
      else
        raise ex
      end
    end
  end

  # ============================================================
  # Android Screenshot Configuration
  # ============================================================
  # Google Play screenshot requirements:
  # - Phone: Min 320px, Max 3840px per side. Recommended 1080x1920 (portrait)
  # - 7-inch tablet: Same requirements. Recommended 1200x1920
  # - 10-inch tablet: Same requirements. Recommended 1600x2560 or 2048x2732
  #
  # Folder structure: metadata/android/en-US/images/{deviceType}Screenshots/
  # Naming: 1.png, 2.png, etc. (1-indexed, up to 8 screenshots)

  # Device configurations for Google Play screenshots
  # Format: { name: display_name, avd: Android Virtual Device name, device_type: folder suffix, target_size: [width, height] }
  # Google Play requires: phoneScreenshots, sevenInchScreenshots, tenInchScreenshots
  ANDROID_SCREENSHOT_DEVICES = {
    phone: {
      name: "Pixel 9 Pro",
      avd: "Pixel_9_Pro",
      device_type: "phone",       # -> phoneScreenshots/
      target_size: [1080, 2400]   # Google Play recommended phone size
    },
    sevenInch: {
      name: "Nexus 7",
      avd: "Nexus_7",
      device_type: "sevenInch",   # -> sevenInchScreenshots/
      target_size: [1200, 1920]   # Google Play 7-inch tablet size
    },
    tenInch: {
      name: "Medium Tablet",
      avd: "Medium_Tablet",
      device_type: "tenInch",     # -> tenInchScreenshots/
      target_size: [1600, 2560]   # Google Play 10-inch tablet size
    }
  }

  desc "Download metadata and screenshots from Google Play"
  lane :screenshots_download do
    supply(
      json_key: ENV["SUPPLY_JSON_KEY"] || "fastlane/google-play-key.json",
      package_name: "com.obsessiontracker.app",
      metadata_path: "fastlane/metadata/android"
    )
    UI.success("✅ Downloaded metadata to fastlane/metadata/android/")
    UI.message("Check en-US/images/ for screenshot folder structure")
  end

  desc "Generate screenshots for Google Play. Usage: screenshots_generate [phone|sevenInch|tenInch] (no arg = all)"
  lane :screenshots_generate do |options|
    # Check for device type - support multiple syntaxes:
    # - device_type:tenInch (explicit key-value)
    # - tenInch:true (boolean flag)
    # - tenInch (bare positional arg via ARGV)
    valid_devices = %w[phone sevenInch tenInch]
    device_arg = options[:device_type]&.to_s ||
                 options[:device]&.to_s ||
                 options.keys.map(&:to_s).find { |k| valid_devices.include?(k) } ||
                 ARGV.find { |arg| valid_devices.include?(arg) }

    if device_arg
      # Single device specified
      unless valid_devices.include?(device_arg)
        UI.user_error!("Invalid device type '#{device_arg}'. Use: phone, sevenInch, or tenInch")
      end
      generate_device_screenshots(device_type: device_arg.to_sym)
      UI.success("✅ #{device_arg} screenshots generated!")
    else
      # No device specified - generate all
      UI.header("Generating ALL screenshots (phone + 7-inch + 10-inch)")

      # Generate phone screenshots
      generate_device_screenshots(device_type: :phone)

      # Generate 7-inch tablet screenshots
      generate_device_screenshots(device_type: :sevenInch)

      # Generate 10-inch tablet screenshots
      generate_device_screenshots(device_type: :tenInch)

      UI.success("✅ All Android screenshots generated!")
    end

    UI.message("📁 Screenshots saved to: fastlane/metadata/android/en-US/images/")
    UI.message("")
    UI.message("To upload screenshots to Google Play, run:")
    UI.message("  fastlane android screenshots_upload")
  end

  desc "Internal: Generate screenshots for a specific device type. Use screenshots_generate instead."
  lane :generate_device_screenshots do |options|
    unless options[:device_type]
      UI.user_error!("device_type is required. Use: screenshots_generate [phone|sevenInch|tenInch]")
    end

    device_type = options[:device_type].to_sym
    device_config = ANDROID_SCREENSHOT_DEVICES[device_type]
    package_name = "com.obsessiontracker.app"

    UI.header("Generating #{device_config[:name]} screenshots")

    # Clean up any orphaned emulators from previous runs (Ctrl+C or crashes)
    # This is critical to prevent memory leaks when running multiple devices
    UI.message("🧹 Cleaning up any orphaned emulators...")

    # First, try graceful ADB shutdown
    system("adb emu kill 2>/dev/null")
    sleep(1)

    # Force kill ALL emulator and qemu processes to ensure clean slate
    UI.message("   Killing any lingering emulator processes...")
    system("pkill -9 -f 'qemu-system' 2>/dev/null")
    system("pkill -9 -f 'emulator64' 2>/dev/null")
    system("pkill -9 -f 'emulator-' 2>/dev/null")
    system("pkill -9 -f 'Android Emulator' 2>/dev/null")
    sleep(3)

    # Restart ADB server fresh
    system("adb kill-server 2>/dev/null")
    sleep(2)
    system("adb start-server")
    sleep(2)

    # Verify no emulators are running
    running_emus = `adb devices 2>/dev/null | grep emulator | wc -l`.strip.to_i
    if running_emus > 0
      UI.important("⚠️ Found #{running_emus} emulator(s) still connected, attempting cleanup...")
      system("adb emu kill 2>/dev/null")
      sleep(3)
    end

    avd_name = device_config[:avd]
    device_type_folder = device_config[:device_type]
    target_size = device_config[:target_size]

    # Target directory for screenshots
    target_dir = "fastlane/metadata/android/en-US/images/#{device_type_folder}Screenshots"

    # Ensure we're in the Flutter project root
    Dir.chdir("..") do
      sh("flutter", "pub", "get")

      # Check if AVD exists, provide instructions if not
      avd_list = `$ANDROID_HOME/emulator/emulator -list-avds 2>/dev/null || emulator -list-avds 2>/dev/null`.strip.split("\n")
      unless avd_list.include?(avd_name)
        UI.error("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
        UI.error("AVD '#{avd_name}' not found!")
        UI.error("")
        UI.error("Available AVDs: #{avd_list.join(', ')}")
        UI.error("")
        UI.error("To create #{device_config[:name]} AVD:")
        UI.error("  1. Open Android Studio")
        UI.error("  2. Tools > Device Manager > Create Device")
        UI.error("  3. Select '#{device_config[:name]}' or similar")
        UI.error("  4. Download API 35 system image")
        UI.error("  5. Name it '#{avd_name}'")
        UI.error("")
        UI.error("Or use an existing AVD:")
        UI.error("  fastlane android generate_device_screenshots device_type:phone avd:YourAVDName")
        UI.error("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
        UI.user_error!("Please create the AVD and try again")
      end

      # Start emulator in background with explicit memory settings
      UI.message("🚀 Starting emulator #{avd_name}...")
      # Use -no-snapshot to prevent memory-heavy snapshot operations
      # Use -gpu swiftshader_indirect for more reliable GPU memory cleanup
      emulator_cmd = "#{ENV['ANDROID_HOME']}/emulator/emulator -avd #{avd_name} -no-snapshot -gpu swiftshader_indirect -memory 2048"
      emulator_pid = spawn(emulator_cmd, [:out, :err] => "/dev/null")
      Process.detach(emulator_pid)
      UI.message("📝 Emulator PID: #{emulator_pid}")

      # Wait for emulator to boot
      # Define emulator serial for targeting commands (handles multiple devices)
      emulator_serial = "emulator-5554"
      UI.message("⏳ Waiting for emulator to boot (serial: #{emulator_serial})...")
      boot_timeout = 120
      boot_start = Time.now
      loop do
        boot_status = `adb -s #{emulator_serial} shell getprop sys.boot_completed 2>/dev/null`.strip
        break if boot_status == "1"

        if Time.now - boot_start > boot_timeout
          UI.user_error!("Emulator failed to boot within #{boot_timeout} seconds")
        end
        sleep(2)
      end
      UI.message("✅ Emulator booted!")

      # Wait for device to be fully ready
      sleep(5)

      # Enable dark mode
      UI.message("🌙 Enabling dark mode...")
      sh("adb", "-s", emulator_serial, "shell", "cmd", "uimode", "night", "yes")

      # Set GPS location to Grand Staircase-Escalante, Utah (where demo data is located)
      UI.message("📍 Setting GPS location to Grand Staircase-Escalante, UT (37.72, -111.42)...")
      sh("adb", "-s", emulator_serial, "emu", "geo", "fix", "-111.42", "37.72") rescue UI.message("GPS location set (may have warning)")

      # Uninstall existing app
      UI.message("🗑️ Uninstalling existing app...")
      sh("adb", "-s", emulator_serial, "uninstall", package_name) rescue UI.message("App wasn't installed")
      sh("adb", "-s", emulator_serial, "uninstall", "#{package_name}.debug") rescue UI.message("Debug app wasn't installed")

      # Build debug APK
      UI.message("🔨 Building debug APK...")
      sh("flutter", "build", "apk", "--debug")

      # Install APK manually first
      UI.message("📲 Installing APK...")
      sh("adb", "-s", emulator_serial, "install", "-r", "build/app/outputs/flutter-apk/app-debug.apk")

      # Grant location permissions (required for GPS features)
      UI.message("🔐 Granting location permissions...")
      sh("adb", "-s", emulator_serial, "shell", "pm", "grant", "#{package_name}.debug", "android.permission.ACCESS_FINE_LOCATION")
      sh("adb", "-s", emulator_serial, "shell", "pm", "grant", "#{package_name}.debug", "android.permission.ACCESS_COARSE_LOCATION")
      system("adb -s #{emulator_serial} shell pm grant #{package_name}.debug android.permission.ACCESS_BACKGROUND_LOCATION 2>/dev/null")

      # Grant camera permission for photo features
      sh("adb", "-s", emulator_serial, "shell", "pm", "grant", "#{package_name}.debug", "android.permission.CAMERA")

      # Push fixture files to /sdcard/ (publicly writable location)
      # The test code will look for fixtures in /sdcard/obsession-fixtures/

      # UT fixtures for land data screenshots
      ut_fixtures_source = "integration_test/fixtures/states/UT"
      if Dir.exist?(ut_fixtures_source) && !Dir.empty?(ut_fixtures_source)
        UI.message("📦 Pushing UT fixture files to device...")
        ut_fixtures_dest = "/sdcard/obsession-fixtures/states/UT"
        sh("adb", "-s", emulator_serial, "shell", "mkdir", "-p", ut_fixtures_dest)
        Dir.glob("#{ut_fixtures_source}/*.zip").each do |zip_file|
          sh("adb", "-s", emulator_serial, "push", zip_file, ut_fixtures_dest + "/")
          UI.message("  📄 Pushed #{File.basename(zip_file)}")
        end
        UI.success("✅ UT fixtures pushed to device")
      end

      # WY fixtures for historical map screenshot
      # Push to /data/local/tmp which is publicly accessible on emulators
      wy_fixtures_source = "integration_test/fixtures/states/WY/historical_maps"
      if Dir.exist?(wy_fixtures_source) && !Dir.empty?(wy_fixtures_source)
        UI.message("📦 Pushing WY historical map fixtures to device...")
        wy_fixtures_dest = "/data/local/tmp/historical_maps/WY/early_topo"

        sh("adb", "-s", emulator_serial, "shell", "mkdir", "-p", wy_fixtures_dest)
        Dir.glob("#{wy_fixtures_source}/*.mbtiles").each do |mbtiles_file|
          filename = File.basename(mbtiles_file)
          sh("adb", "-s", emulator_serial, "push", mbtiles_file, "#{wy_fixtures_dest}/#{filename}")
          UI.message("  📄 Pushed #{filename}")
        end
        UI.success("✅ WY historical map fixtures pushed to device")
      else
        UI.important("⚠️ No WY historical map fixtures found - historical map screenshot will not have overlay")
      end

      # Create target directory
      sh("mkdir", "-p", target_dir)

      # Run flutter drive with Android-specific environment variables
      UI.message("📱 Running screenshot test...")
      ENV["SCREENSHOT_PLATFORM"] = "android"
      ENV["SCREENSHOT_DEVICE_TYPE"] = device_type_folder

      begin
        sh(
          "flutter", "drive",
          "--driver=test_driver/integration_test.dart",
          "--target=integration_test/screenshots_test.dart",
          "-d", "emulator-5554",
          "--no-build"  # Skip rebuild since we already installed
        )
      rescue => ex
        UI.error("Screenshot test failed: #{ex.message}")
        UI.message("Attempting to kill emulator and clean up...")

        # Forcefully kill emulator using PID
        system("adb emu kill 2>/dev/null")
        sleep(1)
        begin
          Process.kill("KILL", emulator_pid) if system("ps -p #{emulator_pid} > /dev/null 2>&1")
        rescue => kill_error
          UI.message("   Kill error (expected if already dead): #{kill_error.message}")
        end

        # Kill any orphaned processes
        system("pkill -9 -f 'qemu.*#{avd_name}' 2>/dev/null")
        system("pkill -9 -f 'emulator.*#{avd_name}' 2>/dev/null")
        sleep(2)

        system("adb kill-server 2>/dev/null")
        sleep(2)
        system("adb start-server")
        raise ex
      end

      UI.success("✅ #{device_config[:name]} screenshots captured!")

      # Resize screenshots if needed
      if target_size
        UI.message("📐 Resizing screenshots to #{target_size[0]}x#{target_size[1]}...")
        Dir.glob("#{target_dir}/*.png").sort.each do |f|
          sh("sips", "-z", target_size[1].to_s, target_size[0].to_s, f, out: File::NULL, err: File::NULL)
          UI.message("  📐 Resized: #{File.basename(f)}")
        end
      end

      # Kill emulator forcefully using stored PID
      UI.message("🛑 Stopping emulator (PID: #{emulator_pid})...")

      # First try graceful shutdown via ADB
      system("adb emu kill 2>/dev/null")
      sleep(2)

      # Then forcefully kill the emulator process if still running
      begin
        if system("ps -p #{emulator_pid} > /dev/null 2>&1")
          UI.message("   Emulator still running, sending SIGTERM...")
          Process.kill("TERM", emulator_pid)
          sleep(3)
        end

        # If still running, force kill
        if system("ps -p #{emulator_pid} > /dev/null 2>&1")
          UI.message("   Emulator still running, sending SIGKILL...")
          Process.kill("KILL", emulator_pid)
          sleep(2)
        end
      rescue Errno::ESRCH
        UI.message("   Emulator process already terminated")
      rescue => e
        UI.message("   Error killing emulator: #{e.message}")
      end

      # Kill any orphaned emulator/qemu processes for this AVD
      UI.message("🧹 Cleaning up any orphaned emulator processes...")
      system("pkill -9 -f 'qemu.*#{avd_name}' 2>/dev/null")
      system("pkill -9 -f 'emulator.*#{avd_name}' 2>/dev/null")
      sleep(2)

      # Restart ADB server to release any held resources
      UI.message("🔄 Restarting ADB server...")
      system("adb kill-server 2>/dev/null")
      sleep(2)
      system("adb start-server")
      sleep(2)

      # Clear emulator temp files to free memory
      UI.message("🗑️ Clearing emulator temp files...")
      avd_path = File.expand_path("~/.android/avd/#{avd_name}.avd")
      if File.directory?(avd_path)
        # Remove hardware-qemu.ini.lock if exists
        lock_file = "#{avd_path}/hardware-qemu.ini.lock"
        File.delete(lock_file) if File.exist?(lock_file)
        # Remove multiinstance.lock if exists
        multiinstance_lock = "#{avd_path}/multiinstance.lock"
        File.delete(multiinstance_lock) if File.exist?(multiinstance_lock)
      end

      UI.success("✅ Emulator cleanup complete")

      # List screenshots with dimensions
      UI.success("✅ #{device_config[:name]} screenshots complete!")
      Dir.glob("#{target_dir}/*.png").sort.each do |f|
        dimensions = `sips -g pixelWidth -g pixelHeight "#{f}" 2>/dev/null | grep pixel | awk '{print $2}' | tr '\n' 'x'`.chomp.sub(/x$/, '')
        UI.message("  📷 #{File.basename(f)} (#{dimensions})")
      end
    end
  end

  desc "Upload screenshots, icon, and feature graphic to Google Play"
  lane :screenshots_upload do
    images_dir = "metadata/android/en-US/images"
    phone_dir = "#{images_dir}/phoneScreenshots"
    seven_inch_dir = "#{images_dir}/sevenInchScreenshots"
    ten_inch_dir = "#{images_dir}/tenInchScreenshots"

    # Check for store presence images
    icon_path = "#{images_dir}/icon.png"
    feature_path = "#{images_dir}/featureGraphic.png"

    if File.exist?(icon_path)
      UI.message("📦 Icon: #{icon_path}")
    else
      UI.important("⚠️ No icon.png found - copy from store_assets/android/app_icon/ic_launcher_512.png")
    end

    if File.exist?(feature_path)
      UI.message("📦 Feature graphic: #{feature_path}")
    else
      UI.important("⚠️ No featureGraphic.png found - copy from store_assets/android/feature_graphic.png")
    end

    # List screenshots
    phone_screenshots = Dir.glob("#{phone_dir}/*.png")
    seven_inch_screenshots = Dir.glob("#{seven_inch_dir}/*.png")
    ten_inch_screenshots = Dir.glob("#{ten_inch_dir}/*.png")

    UI.message("Found #{phone_screenshots.count} phone screenshots")
    UI.message("Found #{seven_inch_screenshots.count} 7-inch tablet screenshots")
    UI.message("Found #{ten_inch_screenshots.count} 10-inch tablet screenshots")

    upload_to_play_store(
      track: "internal",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_images: false,       # Upload icon + feature graphic
      skip_upload_screenshots: false,  # Upload screenshots
      skip_upload_changelogs: true,
      json_key: ENV["SUPPLY_JSON_KEY"] || "fastlane/google-play-key.json"
    )

    UI.success("✅ Screenshots and images uploaded to Google Play!")
  end

  desc "Generate AND upload screenshots to Google Play"
  lane :screenshots_full do
    screenshots_generate
    screenshots_upload
  end

  desc "Deploy a new version to the Google Play Store (builds and uploads binary + changelog only)"
  lane :release do |options|
    # Build number MUST be provided to keep iOS/Android in sync
    build_number = options[:build_number]
    UI.user_error!("build_number is required. Use: fastlane android release build_number:XX") unless build_number

    # Build with Flutter
    sh("flutter", "pub", "get")
    sh("flutter", "clean") unless ENV["SKIP_FLUTTER_CLEAN"]
    sh("flutter", "build", "appbundle",
       "--release",
       "--build-number=#{build_number}")

    # Upload to Google Play production track
    # IMPORTANT: Only upload binary + changelog to avoid triggering content review
    # Metadata/screenshot changes trigger a longer review process
    # Use 'release_full' lane when you actually want to update store listing
    upload_to_play_store(
      track: "production",
      aab: "build/app/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: true,       # Skip to avoid content review
      skip_upload_images: true,         # Skip to avoid content review
      skip_upload_screenshots: true,    # Skip to avoid content review
      skip_upload_changelogs: false,    # Keep changelog for release notes
      json_key: ENV["SUPPLY_JSON_KEY"] || "fastlane/google-play-key.json"
    )

    UI.success("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    UI.success("✅ Build uploaded to production!")
    UI.success("")
    UI.success("Only binary + changelog uploaded (faster review)")
    UI.success("To update store listing, run: fastlane android metadata")
    UI.success("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
  end

  desc "Deploy with ALL metadata (use sparingly - triggers longer content review)"
  lane :release_full do |options|
    # Build number MUST be provided to keep iOS/Android in sync
    build_number = options[:build_number]
    UI.user_error!("build_number is required. Use: fastlane android release_full build_number:XX") unless build_number

    UI.important("⚠️ This uploads ALL metadata which triggers longer content review")
    UI.important("   Use 'fastlane android release' for faster binary-only releases")

    # Build with Flutter
    sh("flutter", "pub", "get")
    sh("flutter", "clean") unless ENV["SKIP_FLUTTER_CLEAN"]
    sh("flutter", "build", "appbundle",
       "--release",
       "--build-number=#{build_number}")

    # Upload to Google Play production track WITH all metadata
    upload_to_play_store(
      track: "production",
      aab: "build/app/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: false,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      skip_upload_changelogs: false,
      json_key: ENV["SUPPLY_JSON_KEY"] || "fastlane/google-play-key.json"
    )
  end

  desc "Promote existing internal/beta build to production (no rebuild)"
  lane :promote do |options|
    # This lane promotes an EXISTING internal/beta build to production.
    # Use this when you already have a build in internal testing that you want to release.
    #
    # Usage:
    #   fastlane android promote                           # Promotes from internal to production
    #   fastlane android promote from:beta                 # Promotes from beta to production
    #   fastlane android promote version_code:123          # Promotes specific version
    #
    # NOTE: Changelogs are uploaded with the promotion. Ensure:
    #   - Changelog is ≤500 characters (Google Play limit)
    #   - File exists: fastlane/metadata/android/en-US/changelogs/{version_code}.txt

    from_track = options[:from] || "internal"
    to_track = options[:to] || "production"
    rollout = options[:rollout] || 1.0  # 1.0 = 100% rollout

    UI.header("Promoting from #{from_track} to #{to_track}")

    # Get version code - either from options or auto-detect from source track
    version_code = options[:version_code]
    unless version_code
      version_codes = google_play_track_version_codes(
        track: from_track,
        json_key: ENV["SUPPLY_JSON_KEY"] || "fastlane/google-play-key.json"
      )
      if version_codes.empty?
        UI.user_error!("No releases found in #{from_track} track")
      end
      version_code = version_codes.first
      UI.message("Auto-detected version code: #{version_code}")
    end

    # Check if changelog exists for this version
    changelog_path = "fastlane/metadata/android/en-US/changelogs/#{version_code}.txt"
    default_changelog = "fastlane/metadata/android/en-US/changelogs/default.txt"

    unless File.exist?(changelog_path)
      if File.exist?(default_changelog)
        UI.message("Creating changelog for version #{version_code} from default.txt")
        FileUtils.cp(default_changelog, changelog_path)
      else
        UI.important("No changelog found for version #{version_code}")
      end
    end

    promote_options = {
      track: from_track,                      # Source track (where the build currently is)
      track_promote_to: to_track,             # Destination track (where to promote it)
      track_promote_release_status: "completed",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: false,          # Upload release notes when promoting to production
      version_code: version_code.to_i,
      json_key: ENV["SUPPLY_JSON_KEY"] || "fastlane/google-play-key.json"
    }

    # If rollout percentage specified (for staged rollout)
    if rollout < 1.0
      promote_options[:rollout] = rollout.to_s
      UI.message("Using staged rollout: #{(rollout * 100).to_i}%")
    end

    # Promote the build
    upload_to_play_store(promote_options)

    UI.success("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    UI.success("✅ Build promoted to #{to_track}!")
    UI.success("")
    if rollout < 1.0
      UI.success("Staged rollout: #{(rollout * 100).to_i}% of users")
      UI.success("To increase rollout: fastlane android promote rollout:0.5")
      UI.success("To complete rollout: fastlane android promote rollout:1.0")
    else
      UI.success("100% rollout - app is now live on Google Play!")
    end
    UI.success("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
  end
end
