<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Obsession</string>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>GPX Track</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.topografix.gpx</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeName</key>
			<string>KML File</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Alternate</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.google.earth.kml</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Obsession Tracker Session</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.obsessiontracker.session</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Obsession Tracker Backup</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.obsessiontracker.backup</string>
			</array>
		</dict>
	</array>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>obsession_tracker</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.navigation</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<key>MBXAccessToken</key>
	<string>$(ACCESS_TOKEN)</string>
	<!-- Privacy: Disable Mapbox telemetry to prevent location/usage data collection -->
	<key>MBXEventsDisabled</key>
	<true/>
	<key>MGLMapboxMetricsEnabled</key>
	<false/>
	<key>MinimumOSVersion</key>
	<string>15.5</string>
	<key>MWDAT</key>
	<dict>
		<key>AppLinkURLScheme</key>
		<string>obsessiontracker://</string>
		<key>MetaAppID</key>
		<string>0</string>
	</dict>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>obsessiontracker</string>
			</array>
		</dict>
	</array>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>fb-viewapp</string>
	</array>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>api.mapbox.com</key>
			<dict>
				<key>NSExceptionRequiresForwardSecrecy</key>
				<false/>
				<key>NSIncludesSubdomains</key>
				<true/>
			</dict>
			<key>events.mapbox.com</key>
			<dict>
				<key>NSExceptionRequiresForwardSecrecy</key>
				<false/>
				<key>NSIncludesSubdomains</key>
				<true/>
			</dict>
		</dict>
	</dict>
	<key>NSCameraUsageDescription</key>
	<string>Obsession Tracker uses your camera to capture photos at waypoints, helping you document your adventures. Photos are stored locally and privately on your device.</string>
	<key>NSDocumentsFolderUsageDescription</key>
	<string>Obsession Tracker can import GPX files and export your tracks to help you share and backup your adventures.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Obsession Tracker can use Face ID to secure your adventure data and provide quick, secure access to the app.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Obsession Tracker can track your location in the background to automatically record your trail, even when the app is not active. All location data remains private and local to your device.</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>Background location access allows Obsession Tracker to continuously record your adventure trail. Your privacy is protected - no location data is shared or uploaded.</string>
	<key>NSLocationUsageDescription</key>
	<string>Obsession Tracker needs location services for compass functionality and GPS tracking during your adventures.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Obsession Tracker needs location access to track your position and create waypoints during your adventures. Your location data stays private and is stored only on your device.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Obsession Tracker can record voice notes at waypoints to help you remember important details about your adventures. Voice recordings are stored privately on your device.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Obsession Tracker uses local network to sync data with your other devices. Your data stays on your local network and is never sent to external servers.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_obstrack._tcp</string>
	</array>
	<key>NSMotionUsageDescription</key>
	<string>Obsession Tracker can use motion data to enhance location accuracy and detect when you're actively moving during adventures.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Obsession Tracker can access your photo library to import images for hunt documentation and waypoint photos. Your photos remain private and are stored only on your device.</string>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>remote-notification</string>
	</array>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIStatusBarHidden</key>
	<false/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>
	<key>UTExportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.xml</string>
			</array>
			<key>UTTypeDescription</key>
			<string>GPS Exchange Format</string>
			<key>UTTypeIdentifier</key>
			<string>com.topografix.gpx</string>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>gpx</string>
				</array>
				<key>public.mime-type</key>
				<array>
					<string>application/gpx+xml</string>
				</array>
			</dict>
		</dict>
		<dict>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
				<string>public.content</string>
			</array>
			<key>UTTypeDescription</key>
			<string>Obsession Tracker Session</string>
			<key>UTTypeIdentifier</key>
			<string>com.obsessiontracker.session</string>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>obstrack</string>
				</array>
				<key>public.mime-type</key>
				<array>
					<string>application/vnd.obsessiontracker.session</string>
				</array>
			</dict>
		</dict>
		<dict>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
				<string>public.content</string>
			</array>
			<key>UTTypeDescription</key>
			<string>Obsession Tracker Backup</string>
			<key>UTTypeIdentifier</key>
			<string>com.obsessiontracker.backup</string>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>obk</string>
				</array>
				<key>public.mime-type</key>
				<array>
					<string>application/vnd.obsessiontracker.backup</string>
				</array>
			</dict>
		</dict>
	</array>
</dict>
</plist>
